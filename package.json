{
  "name": "@halil07/excelize",
  "version": "0.1.0",
  "description": "Read & write Microsoft Excel (XLSX/XLSM/XLTM/XLTX) files in the browser and Node.js via WebAssembly, powered by the Go excelize library.",
  "license": "BSD-3-Clause",
  "author": "halil07",
  "homepage": "https://github.com/halil07/excelize",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halil07/excelize.git"
  },
  "bugs": {
    "url": "https://github.com/halil07/excelize/issues"
  },
  "keywords": [
    "excel",
    "xlsx",
    "spreadsheet",
    "wasm",
    "webassembly",
    "excelize",
    "workbook"
  ],
  "type": "commonjs",
  "main": "dist/excelize.cjs",
  "module": "dist/excelize.mjs",
  "types": "dist/excelize.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/excelize.d.mts",
        "default": "./dist/excelize.mjs"
      },
      "require": {
        "types": "./dist/excelize.d.cts",
        "default": "./dist/excelize.cjs"
      },
      "default": "./dist/excelize.js"
    }
  },
  "files": [
    "dist/excelize.cjs",
    "dist/excelize.mjs",
    "dist/excelize.js",
    "dist/excelize.d.ts",
    "dist/excelize.d.mts",
    "dist/excelize.d.cts",
    "dist/excelize.wasm",
    "dist/wasm_exec.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:go": "node scripts/build.js",
    "build": "pnpm run build:go",
    "postbuild":"pnpm run types",
    "test": "node --test test/excelize.test.mjs",
    "types": "tsc --noEmit test/types.test.ts && tsc --noEmit test/types-cjs.test.cts",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=14"
  }
}